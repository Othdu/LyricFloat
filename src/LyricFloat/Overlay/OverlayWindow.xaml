<Window x:Class="LyricFloat.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LyricFloat"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="OnPanelMouseDown"
        MouseWheel="OnPanelMouseWheel">

    <Border x:Name="RootPanel"
            Visibility="{Binding PanelVisibility}"
            CornerRadius="12"
            Padding="16,12">
        <Border.Background>
            <SolidColorBrush Color="#0E0E12" Opacity="{Binding PanelOpacity}"/>
        </Border.Background>

        <StackPanel Orientation="Horizontal">

            <!-- Album art (Spotify Premium enrichment) -->
            <Border Width="46" Height="46"
                    Margin="0,0,14,0"
                    CornerRadius="8"
                    VerticalAlignment="Center"
                    Visibility="{Binding ArtVisibility}">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding AlbumArt}" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>

            <!-- Lyric lines -->
            <ItemsControl x:Name="LinesControl"
                          ItemsSource="{Binding Lines}"
                          Width="{Binding PanelWidth}"
                          VerticalAlignment="Center">
                <ItemsControl.RenderTransform>
                    <TranslateTransform/>
                </ItemsControl.RenderTransform>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="{Binding FontSize}"
                                   FontWeight="{Binding FontWeight}"
                                   Foreground="{Binding Foreground}"
                                   Opacity="{Binding Opacity}"
                                   FlowDirection="{Binding FlowDirection}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,2">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1.5" Opacity="0.9"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</Window>
