<Window x:Class="LyricFloat.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LyricFloat Settings"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#16161C">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D8D8DE"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6,10,6"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#22222A"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#3A3A44"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#E7C87A"/>
            <Setter Property="Foreground" Value="#16161C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,6,8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D8D8DE"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="22,18">
        <TextBlock Text="Appearance" FontSize="15" FontWeight="SemiBold" Foreground="#E7C87A"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="52"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Text="Background opacity"/>
            <Slider x:Name="OpacitySlider" Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Column="2" Text="{Binding ElementName=OpacitySlider, Path=Value, StringFormat={}{0:P0}}" HorizontalAlignment="Right"/>

            <TextBlock Grid.Row="1" Text="Font size"/>
            <Slider x:Name="FontSlider" Grid.Row="1" Grid.Column="1" Minimum="12" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ElementName=FontSlider, Path=Value, StringFormat={}{0:F0}}" HorizontalAlignment="Right"/>

            <TextBlock Grid.Row="2" Text="Visible lines"/>
            <Slider x:Name="LinesSlider" Grid.Row="2" Grid.Column="1" Minimum="1" Maximum="7" TickFrequency="2" IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding ElementName=LinesSlider, Path=Value, StringFormat={}{0:F0}}" HorizontalAlignment="Right"/>

            <TextBlock Grid.Row="3" Text="Sync offset (ms)"/>
            <Slider x:Name="OffsetSlider" Grid.Row="3" Grid.Column="1" Minimum="-2000" Maximum="2000" TickFrequency="50" IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding ElementName=OffsetSlider, Path=Value, StringFormat={}{0:F0}}" HorizontalAlignment="Right"/>
        </Grid>

        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="Lyrics color" Width="130"/>
            <StackPanel Orientation="Horizontal">
                <StackPanel.Resources>
                    <Style TargetType="Button" x:Key="Swatch">
                        <Setter Property="Width" Value="24"/>
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="0,0,6,0"/>
                        <Setter Property="BorderBrush" Value="#55FFFFFF"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                </StackPanel.Resources>
                <Button Style="{StaticResource Swatch}" Background="#E7C87A" Tag="#E7C87A" Click="OnPresetColor" ToolTip="Champagne gold"/>
                <Button Style="{StaticResource Swatch}" Background="#FFFFFF" Tag="#FFFFFF" Click="OnPresetColor" ToolTip="White"/>
                <Button Style="{StaticResource Swatch}" Background="#1DB954" Tag="#1DB954" Click="OnPresetColor" ToolTip="Spotify green"/>
                <Button Style="{StaticResource Swatch}" Background="#FF4655" Tag="#FF4655" Click="OnPresetColor" ToolTip="Valorant red"/>
                <Button Style="{StaticResource Swatch}" Background="#7FDBFF" Tag="#7FDBFF" Click="OnPresetColor" ToolTip="Ice blue"/>
                <Button Style="{StaticResource Swatch}" Background="#FF6B9D" Tag="#FF6B9D" Click="OnPresetColor" ToolTip="Pink"/>
                <Button Style="{StaticResource Swatch}" Background="#B388FF" Tag="#B388FF" Click="OnPresetColor" ToolTip="Purple"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Custom (hex)" Width="130"/>
            <TextBox x:Name="AccentBox" Width="110" HorizontalAlignment="Left"/>
        </StackPanel>

        <CheckBox x:Name="AnimateBox" Content="Animate line transitions"/>
        <CheckBox x:Name="AutoStartBox" Content="Start with Windows"/>
        <CheckBox x:Name="AlbumArtBox" Content="Show album art (requires Spotify connection)"/>

        <Separator Margin="0,12" Background="#2A2A33"/>

        <TextBlock Text="Spotify Premium enrichment" FontSize="15" FontWeight="SemiBold" Foreground="#E7C87A"/>
        <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                   Text="Optional: millisecond-precise sync + album art. Create a free app at developer.spotify.com, add the redirect URI http://127.0.0.1:8898/callback, then paste its Client ID here."/>
        <TextBlock Text="Client ID" Margin="0,8,0,0"/>
        <TextBox x:Name="ClientIdBox"/>

        <StackPanel Orientation="Horizontal">
            <Button x:Name="ConnectButton" Content="Connect Spotify" Click="OnConnectClick"/>
            <Button x:Name="DisconnectButton" Content="Disconnect" Click="OnDisconnectClick"
                    Background="#3A3A44" Foreground="#D8D8DE"/>
            <TextBlock x:Name="ConnStatus" Margin="8,6" Opacity="0.8"/>
        </StackPanel>

        <Separator Margin="0,12" Background="#2A2A33"/>

        <TextBlock TextWrapping="Wrap" Opacity="0.65" FontSize="12"
                   Text="Hotkeys &#x2014; Ctrl+Shift+L: show/hide &#x2022; Ctrl+Shift+E: edit mode (drag to move, scroll to resize) &#x2022; Ctrl+Shift+S: settings &#x2022; Ctrl+Shift+Up/Down: nudge sync &#x00B1;250ms. For fullscreen games use Borderless Windowed mode."/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Click="OnSaveClick"/>
        </StackPanel>
    </StackPanel>
</Window>
